# Policy Center 环境配置
# 复制此文件为 .env 并修改配置

# 应用
APP_NAME=Policy Center
APP_VERSION=1.0.0
DEBUG=false

# 数据库（SQLite）
DATABASE_URL=sqlite+aiosqlite:///./data/policy_center.db

# 安全（必须修改！）
JWT_SECRET_KEY=your-super-secret-key-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# 存储
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# 日志
LOG_LEVEL=INFO

# 限流
RATE_LIMIT_WEB=100
RATE_LIMIT_AGENT_DEFAULT=60

# 可选：OpenAI（语义搜索）
# OPENAI_API_KEY=sk-xxx
# EMBEDDING_MODEL=text-embedding-3-small
