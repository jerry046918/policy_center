# Policy Center 环境配置
# 复制此文件为 .env 并修改配置

# 应用
APP_NAME=Policy Center
APP_VERSION=0.1.0
DEBUG=false

# 数据库（SQLite）
# Local dev:
DATABASE_URL=sqlite+aiosqlite:///./data/policy_center.db
# Docker (use absolute path matching the volume mount):
# DATABASE_URL=sqlite+aiosqlite:////app/data/policy_center.db

# 安全（必须修改！）
JWT_SECRET_KEY=your-super-secret-key-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# 存储
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# 日志
LOG_LEVEL=INFO

# 限流
RATE_LIMIT_WEB=100
RATE_LIMIT_AGENT_DEFAULT=60

# 可选：OpenAI（语义搜索）
# OPENAI_API_KEY=sk-xxx
# EMBEDDING_MODEL=text-embedding-3-small

# CORS（生产环境请设置具体域名，多个用逗号分隔）
# CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com
# 不设置则 allow_origins=["*"]（仅适合不发送 Cookie 的场景）

# Demo 模式（部署为公开演示站时开启）
# DEMO_MODE=true            启用后：启动时自动完整重置数据库（含用户和 API Key），并按计划定时重置
# DEMO_RESET_CRON=0 3 * * * 重置时间（cron 格式，Asia/Shanghai），默认每天凌晨 3 点
# DEMO_AGENT_API_KEY=pk_live_...  Demo Agent 固定 API Key 明文，重置后保持不变，供你的 agent 使用
#                                 请换成随机字符串（至少32位），不要使用默认值

